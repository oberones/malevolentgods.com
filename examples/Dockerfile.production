# Production Dockerfile for the Malevolent Gods Astro site
#
# This builds the site as static output and serves it with nginx.
# It is intended to sit behind a separate edge nginx reverse proxy
# on the shared Docker network `website-internal`.

FROM node:20-alpine AS build
WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .
RUN npm run build

FROM nginx:alpine AS runtime
WORKDIR /usr/share/nginx/html

RUN rm -rf /usr/share/nginx/html/*
COPY --from=build /app/dist/ /usr/share/nginx/html/
COPY examples/nginx.site-container.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
