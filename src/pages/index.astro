---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import Card from '@/components/Card.astro';
import Container from '@/components/Container.astro';
import Section from '@/components/Section.astro';
import MusicCard from '@/components/MusicCard.astro';
import ArtistCard from '@/components/ArtistCard.astro';
import HomeFeatureList from '@/components/HomeFeatureList.astro';
import { getGlobalSiteData } from '@/lib/content';
import { getHomepageContent } from '@/lib/home-content';

const { settings, fallbackSite } = await getGlobalSiteData();
const hero = settings?.homepageHero || fallbackSite.homepageHero;
const { featuredArtists, featuredMusic, spotlightRelease } = await getHomepageContent();

const homeFeatures = [
  {
    title: 'Curated listening',
    body: 'Artist profiles, albums, singles, and mixes can sit beside one another without getting lost in a pile of embeds.'
  },
  {
    title: 'Gallery space',
    body: 'Visual work can carry cover images, full galleries, and process notes in a form that feels intentional on any screen.'
  },
  {
    title: 'Room for side channels',
    body: 'Writing, hosted apps, and software projects live beside the art and music so the site reads like a real archive of the collective.'
  }
];
---

<BaseLayout title="Home">
  <section class="relative overflow-hidden border-b border-white/5 py-20 sm:py-28">
    <Container class="grid items-start gap-10 lg:grid-cols-[1.15fr_0.85fr]">
      <div>
        <p class="mb-4 text-sm uppercase tracking-[0.35em] text-accentAlt">{hero.eyebrow}</p>
        <h1 class="max-w-4xl text-5xl font-semibold tracking-tight text-text sm:text-6xl lg:text-7xl">
          {hero.title}
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-textMuted sm:text-xl">
          {hero.summary}
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          {hero.primaryCtaLabel && hero.primaryCtaHref && (
            <Button href={hero.primaryCtaHref}>{hero.primaryCtaLabel}</Button>
          )}
          {hero.secondaryCtaLabel && hero.secondaryCtaHref && (
            <Button href={hero.secondaryCtaHref} variant="secondary">{hero.secondaryCtaLabel}</Button>
          )}
        </div>
      </div>

      <Card class="min-h-[320px] bg-gradient-to-br from-surface via-surfaceAlt to-bg">
        <div class="flex h-full flex-col justify-between gap-8">
          <div>
            <p class="text-sm uppercase tracking-[0.3em] text-accentAlt">Current spotlight</p>
            {spotlightRelease ? (
              <>
                <h2 class="mt-4 text-2xl font-semibold text-text">{spotlightRelease.title}</h2>
                <p class="mt-4 text-base leading-7 text-textMuted">{spotlightRelease.summary}</p>
                <div class="mt-6">
                  <a href={spotlightRelease.href} class="inline-flex text-sm font-medium text-accentAlt transition hover:text-text">
                    Open release page →
                  </a>
                </div>
              </>
            ) : (
              <>
                <h2 class="mt-4 text-2xl font-semibold text-text">Curated work across the collective</h2>
                <p class="mt-4 text-base leading-7 text-textMuted">
                  Music, art, writing, and hosted apps all share the same home here, with space for featured releases and quieter archive material alike.
                </p>
              </>
            )}
          </div>
          <HomeFeatureList items={homeFeatures} />
        </div>
      </Card>
    </Container>
  </section>

  <Section
    title="Featured artists"
    intro="Profiles for the artists and aliases currently represented in the music catalog."
  >
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {featuredArtists.map((artist) => (
        <ArtistCard
          name={artist.name}
          shortBio={artist.shortBio}
          href={artist.href}
          links={artist.links}
        />
      ))}
    </div>
  </Section>

  <Section
    title="Featured music"
    intro="A cross-section of albums, singles, and mixes currently surfaced on the site."
    class="pt-0"
  >
    <div class="grid gap-6 lg:grid-cols-3">
      {featuredMusic.map((item) => (
        <MusicCard
          title={item.title}
          summary={item.summary}
          href={item.href}
          embed={item.embed}
        />
      ))}
    </div>
  </Section>

  <Section
    title="What Lives Here"
    intro="The site is meant to hold the work itself, not just point away from it."
    class="pt-0"
  >
    <div class="grid gap-6 lg:grid-cols-3">
      <Card>
        <h3 class="text-xl font-semibold text-text">Connect artists to releases</h3>
        <p class="mt-3 text-sm leading-6 text-textMuted">
          Artist pages can gather related albums, singles, mixes, and platform links in one readable place.
        </p>
      </Card>
      <Card>
        <h3 class="text-xl font-semibold text-text">Give visual work its own space</h3>
        <p class="mt-3 text-sm leading-6 text-textMuted">
          Galleries can hold cover images, process notes, and bodies of work without collapsing into a flat image dump.
        </p>
      </Card>
      <Card>
        <h3 class="text-xl font-semibold text-text">Make room for notes, tools, and apps</h3>
        <p class="mt-3 text-sm leading-6 text-textMuted">
          Writing, project, and app pages let the surrounding systems, ideas, and experiments sit next to the finished work.
        </p>
      </Card>
    </div>
  </Section>
</BaseLayout>
