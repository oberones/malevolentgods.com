---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import HeroPanel from '@/components/HeroPanel.astro';
import ArtProjectCard from '@/components/ArtProjectCard.astro';
import { getFeaturedArtProjects } from '@/lib/art-content';

const artProjects = await getFeaturedArtProjects();
const spotlight = artProjects[0] || null;
const remainingProjects = spotlight ? artProjects.slice(1) : artProjects;
---

<BaseLayout title="Art">
  <section class="py-12 sm:py-16">
    <Section class="py-0">
      <HeroPanel
        eyebrow="Art"
        title="Visual work from the collective, rebuilt with a cleaner gallery structure"
        summary="The art slice is starting with the strongest legacy gallery pages and turning them into cleaner, more intentional project pages."
      />
    </Section>
  </section>

  {spotlight && (
    <Section
      title="Gallery spotlight"
      intro="A first representative art project from the rebuilt section."
      class="pt-0"
    >
      <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-stretch">
        <div class="overflow-hidden rounded-3xl border border-line bg-surface shadow-glow">
          <img src={spotlight.coverImage} alt={`${spotlight.title} cover image`} class="aspect-[4/3] h-full w-full object-cover" />
        </div>
        <div class="flex flex-col justify-between rounded-3xl border border-line bg-surface p-8 shadow-glow">
          <div>
            <p class="text-sm uppercase tracking-[0.3em] text-accentAlt">Featured gallery</p>
            <h3 class="mt-4 text-3xl font-semibold tracking-tight text-text">{spotlight.title}</h3>
            <p class="mt-4 text-base leading-7 text-textMuted">{spotlight.summary}</p>
          </div>
          <div class="mt-8 flex items-center justify-between gap-4 border-t border-white/5 pt-6 text-sm text-textMuted">
            <span>{spotlight.gallery.length} works</span>
            <a href={spotlight.href} class="inline-flex font-medium text-accentAlt transition hover:text-text">
              Open gallery →
            </a>
          </div>
        </div>
      </div>
    </Section>
  )}

  <Section
    title="Featured galleries"
    intro="The first migrated visual projects from the legacy art section."
    class="pt-0"
  >
    <div class="grid gap-6 lg:grid-cols-2">
      {remainingProjects.map((project) => (
        <ArtProjectCard
          title={project.title}
          summary={project.summary}
          href={project.href}
          coverImage={project.coverImage}
        />
      ))}
    </div>
  </Section>
</BaseLayout>
