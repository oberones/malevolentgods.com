---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('writing');
  return entries
    .filter((entry) => entry.data.status === 'published')
    .map((entry) => ({
      params: { slug: entry.slug }
    }));
}

const { slug } = Astro.params;
const entries = await getCollection('writing');
const entry = entries
  .filter((item) => item.data.status === 'published')
  .find((item) => item.slug === slug);

if (!entry) {
  return Astro.redirect('/writing');
}

const { Content } = await render(entry);
const formattedDate = entry.data.publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <section class="border-b border-white/5 py-16 sm:py-20">
    <Container class="max-w-4xl">
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-3 text-sm text-textMuted">
          <span class="uppercase tracking-[0.24em] text-accentAlt">{entry.data.format}</span>
          <span>•</span>
          <time datetime={entry.data.publishedAt.toISOString()}>{formattedDate}</time>
          {entry.data.series && (
            <>
              <span>•</span>
              <span>{entry.data.series}</span>
            </>
          )}
        </div>
        <h1 class="mt-5 text-4xl font-semibold tracking-tight text-text sm:text-5xl">{entry.data.title}</h1>
        <p class="mt-6 text-lg leading-8 text-textMuted">{entry.data.summary}</p>
        {entry.data.tags.length > 0 && (
          <div class="mt-8 flex flex-wrap gap-3">
            {entry.data.tags.map((tag) => (
              <span class="rounded-full border border-line px-4 py-2 text-sm text-textMuted">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </Container>
  </section>

  <section class="py-12 sm:py-16">
    <Container class="max-w-4xl">
      <article class="prose-writing mx-auto max-w-3xl">
        <Content />
      </article>

      <div class="mx-auto mt-12 max-w-3xl border-t border-white/5 pt-8">
        <a href="/writing" class="inline-flex text-sm font-medium text-accentAlt transition hover:text-text">
          ← Back to writing
        </a>
      </div>
    </Container>
  </section>
</BaseLayout>
