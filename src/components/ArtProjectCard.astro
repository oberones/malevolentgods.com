---
import Card from '@/components/Card.astro';
import CoverArt from '@/components/CoverArt.astro';

export interface GalleryItem {
  src: string;
  caption?: string;
}

export interface Props {
  title: string;
  summary?: string;
  href?: string;
  coverImage?: string;
}

const { title, summary, href, coverImage } = Astro.props;
---

<Card class="flex h-full flex-col gap-4">
  <CoverArt src={coverImage} alt={`${title} cover image`} />
  <div>
    <h3 class="text-xl font-semibold text-text">{title}</h3>
    {summary && <p class="mt-3 text-sm leading-6 text-textMuted">{summary}</p>}
    {href && (
      <a href={href} class="mt-4 inline-flex text-sm font-medium text-accentAlt transition hover:text-text">
        View gallery →
      </a>
    )}
  </div>
</Card>
