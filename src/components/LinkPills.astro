---
export interface LinkItem {
  label: string;
  href: string;
}

export interface Props {
  links?: LinkItem[];
}

const { links = [] } = Astro.props;
---

{links.length > 0 && (
  <div class="flex flex-wrap gap-3">
    {links.map((link) => (
      <a
        href={link.href}
        class="inline-flex items-center rounded-full border border-line bg-surface px-4 py-2 text-sm text-textMuted transition hover:border-accent hover:text-text"
      >
        {link.label}
      </a>
    ))}
  </div>
)}
