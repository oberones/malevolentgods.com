---
import Container from './Container.astro';

export interface Props {
  title?: string;
  intro?: string;
  class?: string;
}

const { title, intro, class: className = '' } = Astro.props;
---

<section class={`py-12 sm:py-16 ${className}`}>
  <Container>
    {(title || intro) && (
      <div class="mb-8 max-w-3xl">
        {title && <h2 class="text-3xl font-semibold tracking-tight text-text sm:text-4xl">{title}</h2>}
        {intro && <p class="mt-3 text-base leading-7 text-textMuted sm:text-lg">{intro}</p>}
      </div>
    )}
    <slot />
  </Container>
</section>
